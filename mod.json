{
	"geode": "5.6.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "esilagd.multiplayer",
	"name": "Multiplayer",
	"version": "1.10",
	"developer": "esilagd",
	"description": "a multiplayer for versus",
	"dependencies": {
		"geode.node-ids": ">=v1.23.3"
		"links": {
        "homepage": "https://www.multiplayer.com",
        "source": "https://github.com//",
        "community": "https://discord.gg/"
    },
    "tags": [
        "online", "offline"
    ],
    "settings": {
        "force-no-preload": {
            "type": "",
            "name": "Disable Preloading",
            "description": "Forcibly disables asset preloading, overriding any other option set in Globed settings. This should only be set if Globed crashes on launch due to preloading.",
            "default": false
        },
        "force-preload": {
            "type": "bool",
            "name": "Force Preload",
            "description": "Forces asset preloading regardless of available RAM (only works if preloading is not disabled). When this is disabled (the default), preloading may be skipped if the system is low on RAM.",
            "default": false
        },
        "keybinds-title": {
            "type": "title",
            "name": "Keybinds"
        },
        "keybind-voice-chat": {
            "type": "keybind",
            "name": "Voice Chat Activate",
            "description": "Activates voice chat when held, allowing you to talk to other players in the same level",
            "default": "V"
        },
        "keybind-deafen": {
            "type": "keybind",
            "name": "Deafen",
            "description": "Toggles deafen mode, which prevents you from hearing other players and talking in voice chat",
            "default": "B"
        },
        "keybind-hide-players": {
            "type": "keybind",
            "name": "Hide Players",
            "description": "Toggles visibility of other players in a level",
            "default": []
        },
        "keybind-emote-0": {
            "type": "keybind",
            "name": "Emote 1",
            "default": []
        },
        "keybind-emote-1": {
            "type": "keybind",
            "name": "Emote 2",
            "default": []
        },
        "keybind-emote-2": {
            "type": "keybind",
            "name": "Emote 3",
            "default": []
        },
        "keybind-emote-3": {
            "type": "keybind",
            "name": "Emote 4",
            "default": []
        },
        "keybind-emote-4": {
            "type": "keybind",
            "name": "Emote 5",
            "default": []
        },
        "keybind-emote-5": {
            "type": "keybind",
            "name": "Emote 6",
            "default": []
        },
        "keybind-emote-6": {
            "type": "keybind",
            "name": "Emote 7",
            "default": []
        },
        "keybind-emote-7": {
            "type": "keybind",
            "name": "Emote 8",
            "default": []
        },
        "keybind-force-switch": {
            "type": "keybind",
            "name": "Force Switch",
            "default": []
        }
    },
    "resources": {
        "sprites": [
            "resources/misc/*.png",
            "resources/menu/*.png",
            "resources/featured/*.png",
            "resources/roles/*.png",
            "resources/mod/*.png",
            "resources/game/*.png"
        ],
        "spritesheets": {
            "twemojis": [
                "resources/emoji/*.png"
            ],
            "emotes": [
                "resources/emotes_sprites/*.png"
            ]
        },
        "fonts": {
            "Consolas": {
                "path": "resources/fonts/Consolas-Regular.ttf",
                "size": 64
            }
        },
        "files": [
            "resources/emotes_sfx/*.ogg"
        ]
    },
    "api": {
        "include": [
            "include/globed/*.hpp",
            "include/globed/audio/*.hpp",
            "include/globed/audio/sound/*.hpp",
            "include/globed/core/*.hpp",
            "include/globed/core/data/*.hpp",
            "include/globed/core/game/*.hpp",
            "include/globed/core/net/*.hpp",
            "include/globed/soft-link/*.hpp",
            "include/globed/util/*.hpp"
        ]
    }
}
